{
  "name": "cooper",
  "displayName": "Cooper — OpenSNES IDE",
  "description": "All-in-one SNES game development for the OpenSNES SDK + luna emulator: WLA-DX 65816 highlighting, C support via clangd, and project tooling.",
  "version": "0.5.0",
  "publisher": "opensnes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/k0b3n4irb/cooper.git"
  },
  "bugs": {
    "url": "https://github.com/k0b3n4irb/cooper/issues"
  },
  "homepage": "https://github.com/k0b3n4irb/cooper#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onDebugResolve:luna"
  ],
  "categories": [
    "Programming Languages",
    "Extension Packs"
  ],
  "extensionPack": [
    "llvm-vs-code-extensions.vscode-clangd"
  ],
  "keywords": [
    "snes",
    "65816",
    "wla-dx",
    "assembly",
    "opensnes"
  ],
  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "test": "node test/run.js",
    "compile-tests": "tsc -p tsconfig.test.json",
    "test:integration": "npm run compile && npm run compile-tests && vscode-test",
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production"
  },
  "contributes": {
    "languages": [
      {
        "id": "wla65816",
        "aliases": [
          "WLA-DX 65816 Assembly",
          "wla-dx",
          "wla65816"
        ],
        "extensions": [
          ".asm",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wla65816",
        "scopeName": "source.wla65816",
        "path": "./syntaxes/wla65816.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "cooper.configureClangd",
        "title": "Configure clangd (OpenSNES C support)",
        "category": "Cooper"
      },
      {
        "command": "cooper.build",
        "title": "Build (make)",
        "category": "Cooper"
      },
      {
        "command": "cooper.preview",
        "title": "Preview frame (luna screenshot)",
        "category": "Cooper"
      }
    ],
    "taskDefinitions": [
      {
        "type": "cooper-make",
        "required": [],
        "properties": {
          "target": {
            "type": "string",
            "description": "The make target to run (default: the project's default goal, which builds the ROM)."
          }
        }
      }
    ],
    "debuggers": [
      {
        "type": "luna",
        "label": "Luna SNES Debug",
        "languages": [
          "c",
          "wla65816"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .sfc/.smc ROM to debug (its sibling .sym provides symbols).",
                "default": "${workspaceFolder}/game.sfc"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at the reset vector when the ROM loads.",
                "default": true
              },
              "maxSteps": {
                "type": "number",
                "description": "Instruction budget for a Continue before it pauses (no breakpoint hit).",
                "default": 5000000
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "luna",
            "request": "launch",
            "name": "Luna: Debug SNES ROM",
            "program": "${workspaceFolder}/game.sfc",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "Cooper: Debug SNES ROM in luna",
            "description": "Launch a .sfc ROM under the luna debugger",
            "body": {
              "type": "luna",
              "request": "launch",
              "name": "Luna: Debug SNES ROM",
              "program": "^\"\\${workspaceFolder}/${1:game}.sfc\"",
              "stopOnEntry": true
            }
          }
        ]
      }
    ],
    "problemMatchers": [
      {
        "name": "cooper-cc",
        "owner": "cpp",
        "source": "cc65816",
        "fileLocation": "autoDetect",
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    ],
    "configuration": {
      "title": "Cooper",
      "properties": {
        "cooper.opensnesPath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "markdownDescription": "Absolute path to the OpenSNES SDK root (the folder containing `lib/include/snes.h`). Used by **Cooper: Configure clangd** to generate the `.clangd` file. If empty, Cooper infers it from the project Makefile's `OPENSNES` line, then by searching parent folders."
        },
        "cooper.lunaPath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "markdownDescription": "Absolute path to the `luna` emulator binary used by **Cooper: Preview frame**. If empty, Cooper uses the SDK's pinned binary at `<sdk>/tools/luna-test/bin/luna`."
        },
        "cooper.preview.steps": {
          "type": "number",
          "default": 200000,
          "minimum": 1,
          "markdownDescription": "CPU instructions luna executes before grabbing the preview screenshot. Lower values may render a black frame before the ROM has drawn anything; 200000 is past init for typical demos."
        },
        "cooper.preview.forceDisplay": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Pass `--force-display` so the preview bypasses INIDISP forced-blank — shows what the ROM uploaded to VRAM/CGRAM even if it left the screen blanked (e.g. a title waiting on Start)."
        }
      }
    }
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.1",
    "@types/vscode": "~1.75.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "mocha": "^11.7.6",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0"
  }
}
