{
  "name": "cooper",
  "displayName": "Cooper — OpenSNES IDE",
  "description": "All-in-one SNES game development for the OpenSNES SDK + luna emulator: WLA-DX 65816 highlighting, C support via clangd, and project tooling.",
  "version": "0.62.0",
  "publisher": "opensnes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/k0b3n4irb/cooper.git"
  },
  "bugs": {
    "url": "https://github.com/k0b3n4irb/cooper/issues"
  },
  "homepage": "https://github.com/k0b3n4irb/cooper#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onDebugResolve:luna",
    "onLanguage:c",
    "onView:cooperTree"
  ],
  "categories": [
    "Programming Languages",
    "Extension Packs"
  ],
  "extensionPack": [
    "llvm-vs-code-extensions.vscode-clangd"
  ],
  "keywords": [
    "snes",
    "65816",
    "wla-dx",
    "assembly",
    "opensnes"
  ],
  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "test": "node test/run.js",
    "compile-tests": "tsc -p tsconfig.test.json",
    "test:integration": "npm run compile && npm run compile-tests && vscode-test",
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production"
  },
  "contributes": {
    "languages": [
      {
        "id": "wla65816",
        "aliases": [
          "WLA-DX 65816 Assembly",
          "wla-dx",
          "wla65816"
        ],
        "extensions": [
          ".asm",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wla65816",
        "scopeName": "source.wla65816",
        "path": "./syntaxes/wla65816.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "cooper.configureClangd",
        "title": "Configure C Support (clangd)",
        "category": "Cooper",
        "icon": "$(tools)"
      },
      {
        "command": "cooper.build",
        "title": "Build",
        "category": "Cooper",
        "icon": "$(package)"
      },
      {
        "command": "cooper.preview",
        "title": "Run Preview",
        "category": "Cooper",
        "icon": "$(device-camera)"
      },
      {
        "command": "cooper.play",
        "title": "Play (native window)",
        "category": "Cooper",
        "icon": "$(game)"
      },
      {
        "command": "cooper.showPalette",
        "title": "Show Palette (CGRAM)",
        "category": "Cooper",
        "icon": "$(symbol-color)"
      },
      {
        "command": "cooper.showOam",
        "title": "Show Sprites (OAM)",
        "category": "Cooper",
        "icon": "$(preview)"
      },
      {
        "command": "cooper.showVram",
        "title": "Show Tiles (VRAM)",
        "category": "Cooper",
        "icon": "$(layout)"
      },
      {
        "command": "cooper.refresh",
        "title": "Refresh",
        "category": "Cooper",
        "icon": "$(refresh)"
      },
      {
        "command": "cooper.home",
        "title": "Show Dashboard",
        "category": "Cooper",
        "icon": "$(home)"
      },
      {
        "command": "cooper.openWalkthrough",
        "title": "Get Started",
        "category": "Cooper",
        "icon": "$(book)"
      },
      {
        "command": "cooper.editPalette",
        "title": "Edit Palette",
        "category": "Cooper",
        "icon": "$(symbol-color)"
      },
      {
        "command": "cooper.editTiles",
        "title": "Edit Tiles",
        "category": "Cooper",
        "icon": "$(paintcan)"
      },
      {
        "command": "cooper.viewTilemap",
        "title": "Show Tilemap",
        "category": "Cooper",
        "icon": "$(map)"
      },
      {
        "command": "cooper.configureAI",
        "title": "Configure AI (OpenSNES context)",
        "category": "Cooper",
        "icon": "$(sparkle)"
      },
      {
        "command": "cooper.debug",
        "title": "Debug",
        "category": "Cooper",
        "icon": "$(debug-alt)"
      },
      {
        "command": "cooper.breakOnSymbol",
        "title": "Toggle Breakpoint on Function…",
        "category": "Cooper",
        "icon": "$(circle-filled)"
      },
      {
        "command": "cooper.showLog",
        "title": "Show Log",
        "category": "Cooper",
        "icon": "$(output)"
      },
      {
        "command": "cooper.saveSnapshot",
        "title": "Save Debug Snapshot",
        "category": "Cooper",
        "icon": "$(save)"
      },
      {
        "command": "cooper.restoreSnapshot",
        "title": "Restore Debug Snapshot…",
        "category": "Cooper",
        "icon": "$(history)"
      },
      {
        "command": "cooper.showDisasm",
        "title": "Show Disassembly",
        "category": "Cooper",
        "icon": "$(file-code)"
      },
      {
        "command": "cooper.traceMemory",
        "title": "Trace Memory Access (one frame)…",
        "category": "Cooper",
        "icon": "$(pulse)"
      },
      {
        "command": "cooper.newProject",
        "title": "New Project (from an SDK example)…",
        "category": "Cooper",
        "icon": "$(new-folder)"
      },
      {
        "command": "cooper.watch",
        "title": "Toggle Watch (rebuild on save)",
        "category": "Cooper",
        "icon": "$(eye)"
      },
      {
        "command": "cooper.showMemoryMap",
        "title": "Show Memory Map (WRAM/VRAM)",
        "category": "Cooper",
        "icon": "$(graph)"
      },
      {
        "command": "cooper.replayInputs",
        "title": "Replay Inputs…",
        "category": "Cooper",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "cooper.validateRom",
        "title": "Validate ROM",
        "category": "Cooper",
        "icon": "$(verified)"
      },
      {
        "command": "cooper.deployRom",
        "title": "Deploy ROM (to flashcart)…",
        "category": "Cooper",
        "icon": "$(rocket)"
      },
      {
        "command": "cooper.profileFrame",
        "title": "Run Profiler (one frame)",
        "category": "Cooper",
        "icon": "$(dashboard)"
      },
      {
        "command": "cooper.audition",
        "title": "Audition Audio (hear the game)…",
        "category": "Cooper",
        "icon": "$(unmute)"
      },
      {
        "command": "cooper.recordGameplayTest",
        "title": "Record Gameplay Test…",
        "category": "Cooper",
        "icon": "$(record)"
      },
      {
        "command": "cooper.runGameplayTests",
        "title": "Run Gameplay Tests",
        "category": "Cooper",
        "icon": "$(beaker)"
      },
      {
        "command": "cooper.importRecording",
        "title": "Import Recording…",
        "category": "Cooper",
        "icon": "$(cloud-download)"
      },
      {
        "command": "cooper.newSprite",
        "title": "New Sprite (draw one)…",
        "category": "Cooper",
        "icon": "$(edit)"
      },
      {
        "command": "cooper.newSoundEffect",
        "title": "New Sound Effect (synth)…",
        "category": "Cooper",
        "icon": "$(music)"
      },
      {
        "command": "cooper.newTilemap",
        "title": "New Tilemap (Tiled)…",
        "category": "Cooper",
        "icon": "$(map)"
      },
      {
        "command": "cooper.addSprite",
        "title": "Add Sprite (from a PNG)…",
        "category": "Cooper",
        "icon": "$(file-media)"
      },
      {
        "command": "cooper.addSoundEffect",
        "title": "Add Sound Effect (from a WAV)…",
        "category": "Cooper",
        "icon": "$(unmute)"
      },
      {
        "command": "cooper.exportMetasprite",
        "title": "Export Metasprite / Animation…",
        "category": "Cooper",
        "icon": "$(symbol-class)"
      },
      {
        "command": "cooper.setGraphicsMode",
        "title": "Set Graphics Mode…",
        "category": "Cooper",
        "icon": "$(settings)"
      },
      {
        "command": "cooper.createNewGame",
        "title": "New Game (guided)…",
        "category": "Cooper",
        "shortTitle": "SNES Game (guided)…",
        "icon": "$(add)"
      },
      {
        "command": "cooper.insertSnippet",
        "title": "Add Snippet (collision, …)…",
        "category": "Cooper",
        "icon": "$(symbol-snippet)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cooper",
          "title": "Cooper",
          "icon": "media/cooper.svg"
        }
      ]
    },
    "views": {
      "cooper": [
        {
          "id": "cooperTree",
          "name": "OpenSNES"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "cooper.editPalette",
          "when": "resourceExtname == .png",
          "group": "cooper@1"
        },
        {
          "command": "cooper.editTiles",
          "when": "resourceExtname == .png",
          "group": "cooper@2"
        },
        {
          "command": "cooper.viewTilemap",
          "when": "resourceExtname == .map",
          "group": "cooper@1"
        },
        {
          "command": "cooper.exportMetasprite",
          "when": "resourceExtname == .png",
          "group": "cooper@3"
        },
        {
          "command": "cooper.addSprite",
          "when": "resourceExtname == .png",
          "group": "cooper@4"
        },
        {
          "command": "cooper.addSoundEffect",
          "when": "resourceExtname == .wav",
          "group": "cooper@5"
        },
        {
          "command": "cooper.insertSnippet",
          "when": "resourceExtname == .c",
          "group": "cooper@6"
        },
        {
          "command": "cooper.play",
          "when": "resourceExtname == .sfc || resourceExtname == .smc",
          "group": "cooper@1"
        },
        {
          "command": "cooper.validateRom",
          "when": "resourceExtname == .sfc || resourceExtname == .smc",
          "group": "cooper@2"
        },
        {
          "command": "cooper.deployRom",
          "when": "resourceExtname == .sfc || resourceExtname == .smc",
          "group": "cooper@3"
        }
      ],
      "file/newFile": [
        {
          "command": "cooper.createNewGame",
          "group": "file"
        }
      ],
      "view/title": [
        {
          "command": "cooper.createNewGame",
          "when": "view == cooperTree",
          "group": "navigation@0"
        },
        {
          "command": "cooper.home",
          "when": "view == cooperTree",
          "group": "navigation@1"
        },
        {
          "command": "cooper.openWalkthrough",
          "when": "view == cooperTree",
          "group": "navigation@2"
        },
        {
          "command": "cooper.refresh",
          "when": "view == cooperTree",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "command": "cooper.insertSnippet",
          "when": "resourceExtname == .c",
          "group": "cooper@1"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "cooper.gettingStarted",
        "title": "Get Started with Cooper",
        "description": "Build, run and debug SNES games on the OpenSNES SDK + luna — in a few clicks.",
        "steps": [
          {
            "id": "tools",
            "title": "Point Cooper at your tools",
            "description": "Your game lives in its own folder; OpenSNES and luna are installed separately — **download** the prebuilt build for your architecture (no compiler to install).\n\n**Get them:** the OpenSNES SDK zip for your OS/arch from https://github.com/k0b3n4irb/opensnes/releases (extract it — `cc65816`/`qbe`/`wla-65816` are in its `bin/`), and **luna** from https://github.com/k0b3n4irb/luna/releases/latest . Then point Cooper at them:\n\n[Set the OpenSNES SDK path](command:workbench.action.openSettings?%22cooper.opensnesPath%22)\n[Set the luna path](command:workbench.action.openSettings?%22cooper.lunaPath%22)\n\n`cooper.lunaPath` accepts the luna binary **or** the folder that contains it.",
            "media": {
              "image": "media/cooper-dashboard.png",
              "altText": "The Cooper dashboard with SDK/luna status"
            },
            "completionEvents": [
              "onSettingChanged:cooper.opensnesPath"
            ]
          },
          {
            "id": "project",
            "title": "Create your first game (guided)",
            "description": "Answer a short survey — **what kind of game?** (platformer, RPG, shmup, racing…) — tick the hardware you want (sound, SRAM save, SA-1, SuperFX…), and Cooper generates the whole project: Makefile, libraries, graphics mode, and a starter where **you already move a character with the D-pad**.\n\n[🎮 New Game…](command:cooper.createNewGame)\n\nPrefer starting from a real SDK example (breakout, hello_world…)? [New Project…](command:cooper.newProject) — or just open an existing project folder.",
            "media": {
              "image": "media/cooper-preview.png",
              "altText": "A freshly built game frame"
            },
            "completionEvents": [
              "onCommand:cooper.createNewGame",
              "onCommand:cooper.newProject"
            ]
          },
          {
            "id": "sidebar",
            "title": "Open the Cooper panel",
            "description": "Click the **Cooper** icon (a gamepad) in the activity bar. Everything is one click — Build, Run, Debug, PPU viewers, and your project's functions.\n\n[Open the Cooper panel](command:workbench.view.extension.cooper)",
            "media": {
              "image": "media/cooper-sidebar.png",
              "altText": "The Cooper sidebar tree"
            },
            "completionEvents": [
              "onView:cooperTree"
            ]
          },
          {
            "id": "build",
            "title": "Build your ROM",
            "description": "Compile with `make`. Cooper passes your SDK path automatically, so it works from any folder. Errors land in the Problems panel.\n\n[Build (make)](command:cooper.build)",
            "media": {
              "image": "media/cooper-dashboard.png",
              "altText": "The Cooper dashboard"
            },
            "completionEvents": [
              "onCommand:cooper.build"
            ]
          },
          {
            "id": "run",
            "title": "Run a frame",
            "description": "Render a frame in luna and see it inline — your game, on cycle-accurate hardware.\n\n[Run / Preview](command:cooper.preview)",
            "media": {
              "image": "media/cooper-preview.png",
              "altText": "A rendered SNES frame"
            },
            "completionEvents": [
              "onCommand:cooper.preview"
            ]
          },
          {
            "id": "create",
            "title": "Make it yours — art, sound, code",
            "description": "Everything you need to turn the starter into *your* game, no external tools required:\n\n[✏️ New Sprite (draw one)…](command:cooper.newSprite) — a blank canvas at your mode's sprite size, opened in the paint editor. Then **Add Sprite** wires it into the game with the tile numbers computed.\n\n[🔊 Add Sound Effect (from a WAV)…](command:cooper.addSoundEffect) — Cooper builds the soundbank and hands you the C to play it.\n\n[🧩 Add Snippet (collision, …)…](command:cooper.insertSnippet) — working, SDK-correct code (AABB collision, tile collision…), with the Makefile wired for you.",
            "media": {
              "image": "media/cooper-dashboard.png",
              "altText": "The Cooper dashboard"
            },
            "completionEvents": [
              "onCommand:cooper.newSprite",
              "onCommand:cooper.addSoundEffect",
              "onCommand:cooper.insertSnippet"
            ]
          },
          {
            "id": "debug",
            "title": "Debug your game",
            "description": "In the Cooper panel under **SYMBOLS**, click one of your functions to set a breakpoint, then start debugging and press **Continue**. Inspect CPU registers, memory and the live PPU at the stop.\n\n[Start Debugging](command:cooper.debug)",
            "media": {
              "image": "media/cooper-sidebar.png",
              "altText": "Symbols and Debug in the Cooper panel"
            },
            "completionEvents": [
              "onCommand:cooper.debug"
            ]
          },
          {
            "id": "viewers",
            "title": "Inspect the PPU",
            "description": "At a debug stop, view the live **Palette**, **Sprites (OAM)** and **Tiles (VRAM)** — decoded straight from the emulator.\n\n[Open the Dashboard](command:cooper.home)",
            "media": {
              "image": "media/cooper-vram.png",
              "altText": "A decoded VRAM tile sheet"
            },
            "completionEvents": [
              "onCommand:cooper.home",
              "onCommand:cooper.showVram"
            ]
          }
        ]
      }
    ],
    "taskDefinitions": [
      {
        "type": "cooper-make",
        "required": [],
        "properties": {
          "target": {
            "type": "string",
            "description": "The make target to run (default: the project's default goal, which builds the ROM)."
          }
        }
      }
    ],
    "debuggers": [
      {
        "type": "luna",
        "label": "Luna SNES Debug",
        "languages": [
          "c",
          "wla65816"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "program": {
                "type": "string",
                "description": "Optional path to the .sfc/.smc ROM. If omitted, Cooper resolves it from the project's Makefile TARGET (recommended — stays correct if you restructure the project)."
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at the reset vector when the ROM loads.",
                "default": true
              },
              "maxSteps": {
                "type": "number",
                "description": "Instruction budget for a Continue before it pauses (no breakpoint hit).",
                "default": 5000000
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "luna",
            "request": "launch",
            "name": "Luna: Debug SNES ROM",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "Cooper: Debug SNES ROM in luna",
            "description": "Launch the project's ROM under the luna debugger (resolved from the Makefile)",
            "body": {
              "type": "luna",
              "request": "launch",
              "name": "Luna: Debug SNES ROM",
              "stopOnEntry": true
            }
          }
        ]
      }
    ],
    "problemMatchers": [
      {
        "name": "cooper-cc",
        "owner": "cpp",
        "source": "cc65816",
        "fileLocation": "autoDetect",
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    ],
    "configuration": {
      "title": "Cooper",
      "properties": {
        "cooper.opensnesPath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "markdownDescription": "Absolute path to the OpenSNES SDK root (the folder containing `lib/include/snes.h`). Used to generate the `.clangd` file. If empty, Cooper infers it from the project Makefile's `OPENSNES` line, then by searching parent folders.",
          "description": "Path to the OpenSNES SDK root (the folder containing lib/include/snes.h). Leave empty to auto-detect from the project Makefile.",
          "order": 1
        },
        "cooper.autoConfigureClangd": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Automatically write a `.clangd` for C IntelliSense when you open a C file in an OpenSNES project (never overwrites an existing one). Turn off to configure manually with **Cooper: Configure clangd**.",
          "description": "Automatically write the project .clangd (C IntelliSense flags) when an OpenSNES project is opened.",
          "order": 3
        },
        "cooper.lunaPath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "markdownDescription": "Path to the `luna` emulator — the **binary** or the **folder** that contains it (a user release unzips to a folder with `luna`/`luna-gui`). If empty, Cooper uses the SDK's pinned binary at `<sdk>/tools/luna-test/bin/luna`, then `luna` on your PATH.",
          "order": 2
        },
        "cooper.preview.steps": {
          "type": "number",
          "default": 200000,
          "minimum": 1,
          "markdownDescription": "CPU instructions luna executes before grabbing the preview screenshot. Lower values may render a black frame before the ROM has drawn anything; 200000 is past init for typical demos."
        },
        "cooper.preview.forceDisplay": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Pass `--force-display` so the preview bypasses INIDISP forced-blank — shows what the ROM uploaded to VRAM/CGRAM even if it left the screen blanked (e.g. a title waiting on Start)."
        },
        "cooper.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show '◉ break · ▶ debug here' CodeLens above your project's C functions."
        },
        "cooper.deployPath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Where 'Deploy ROM' copies the built ROM (e.g. the flashcart SD card mount point)."
        }
      }
    }
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.1",
    "@types/vscode": "~1.75.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "mocha": "^11.7.6",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0"
  }
}
